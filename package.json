{
  "name": "cmdgen",
  "version": "0.1.0",
  "bin": {
    "cmdgen": "./dist/cli.js"
  },
  "files": ["dist"],
  "type": "module",
  "scripts": {
    "build": "bun build --target=node --format=esm --packages=external --outfile=dist/cli.js --banner='#!/usr/bin/env node' ./src/bin.ts",
    "prepare": "bun run build",
    "prepack": "bun run build",
    "test": "vitest run",
    "check": "oxfmt . && oxlint --type-aware --type-check .",
    "fix": "oxfmt --write . && oxlint --type-aware --type-check --fix --fix-suggestions --fix-dangerously ."
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.65.2",
    "@mariozechner/pi-coding-agent": "^0.65.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
