{
  "name": "cmdgen",
  "version": "0.1.0",
  "bin": {
    "cmdgen": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build:bun": "mkdir -p dist && bun build --target=node --format=esm --packages=external --outfile=dist/cli.js --banner='#!/usr/bin/env node' ./src/bin.ts",
    "build:rolldown": "mkdir -p dist && npx rolldown ./src/bin.ts --platform node --format esm --inline-dynamic-imports --file dist/cli.js --external @mariozechner/pi-ai,@mariozechner/pi-coding-agent --banner '#!/usr/bin/env node'",
    "build": "if command -v bun >/dev/null 2>&1; then npm run build:bun; else npm run build:rolldown; fi",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "check": "oxfmt . && oxlint --type-aware --type-check .",
    "fix": "oxfmt --write . && oxlint --type-aware --type-check --fix --fix-suggestions --fix-dangerously ."
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.65.2",
    "@mariozechner/pi-coding-agent": "^0.65.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
